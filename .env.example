# Database URL
#
# Option A — SQLite (default, no external database needed):
AKUP_DATABASE_URL=sqlite+aiosqlite:///./akup.db
#
# Option B — PostgreSQL via Docker Compose (matches docker-compose.yml defaults):
# AKUP_DATABASE_URL=postgresql+asyncpg://akup:akup@localhost:5432/akup
#
# Option C — PostgreSQL on Azure or another remote host:
# AKUP_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/akup

# Echo SQL queries to stdout (useful for debugging)
AKUP_ECHO_SQL=false
